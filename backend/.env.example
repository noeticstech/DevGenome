NODE_ENV=development
PORT=4000
API_PREFIX=/api
APP_ORIGIN=http://localhost:5173
TRUSTED_APP_ORIGINS=http://localhost:5173
TRUST_PROXY=false
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/devgenome
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:5173/auth/github/callback
SESSION_SECRET=replace_this_with_a_long_random_secret_value
TOKEN_ENCRYPTION_SECRET=replace_this_with_a_different_long_random_secret_value
SESSION_TTL_HOURS=168
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_DOMAIN=
REQUEST_BODY_LIMIT_KB=256
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_MS=15000
CACHE_ENABLED=true
PRODUCT_RESPONSE_CACHE_TTL_MS=30000
ANALYSIS_SNAPSHOT_CACHE_TTL_MS=30000
AI_RESPONSE_CACHE_TTL_MS=900000
JOB_WORKER_ENABLED=true
JOB_SCHEDULER_ENABLED=true
JOB_POLL_INTERVAL_MS=3000
JOB_CONCURRENCY=1
JOB_RETRY_BASE_DELAY_MS=60000
JOB_SCHEDULER_INTERVAL_MS=300000
GITHUB_SYNC_INTERVAL_MINUTES=720
LEETCODE_SYNC_INTERVAL_MINUTES=1440
CODEFORCES_SYNC_INTERVAL_MINUTES=1440
